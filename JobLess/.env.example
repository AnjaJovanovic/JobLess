# =============================================================================
# Kopirati ovaj fajl u .env (isto ime, bez .example) i popuniti vrednosti.
# Docker Compose automatski učitava .env iz ovog foldera (JobLess/JobLess).
#
# Windows napomene:
# - Kreirati fajl tačno kao ".env" (ne ".env.txt"). U Explorer-u uključiti
#   prikaz ekstenzija ako je potrebno.
# - Sačuvati kao UTF-8 (bez BOM). CRLF (Windows) ili LF su OK.
# - Vrednosti ne stavljati u navodnike osim ako sadrže razmake.
# - Specijalni karakteri u lozinkama (#, $, !, &) mogu praviti probleme
#   Compose substituciji; u tom slučaju koristiti jednostavniju lozinku
#   ili staviti vrednost u duple navodnike.
# - SQL_SA / SA lozinka mora ispunjavati SQL Server politiku jačine
#   (dužina, veliko/malo slovo, cifra, specijalni karakter).
# =============================================================================

# sql server (mora se zvati SA_PASSWORD — isto ime kao u docker-compose.yml)
SA_PASSWORD=

# jwt token
JWT_KEY=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_EXPIRATION_MINUTES=

# rabbitMQ
RABBITMQ_USER=
RABBITMQ_PASSWORD=

# SMTP za Gmail
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
